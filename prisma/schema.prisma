generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @map("userId") @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("users")
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

model Service {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  slug        String   @unique
  description String
  shortDesc   String
  image       String?
  icon        String   @default("Sparkles")
  features    String[]
  priceRange  String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  metaTitle   String?
  metaDesc    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("services")
}

model BlogPost {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  slug        String   @unique
  content     String
  excerpt     String
  image       String?
  category    String
  tags        String[]
  author      String   @default("Günen Temizlik")
  published   Boolean  @default(false)
  views       Int      @default(0)
  metaTitle   String?
  metaDesc    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("blogposts")
}

model ContactRequest {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String
  phone     String?
  service   String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contactrequests")
}

model Testimonial {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  location  String?
  rating    Int      @default(5)
  content   String
  avatar    String?
  service   String?
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@map("testimonials")
}

model Subscriber {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  name      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("subscribers")
}

model SiteSettings {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  siteName        String   @default("Günen Temizlik")
  siteDescription String?
  siteUrl         String   @default("https://gunentemizlik.com")
  logo            String?
  favicon         String   @default("/favicon.ico")
  primaryColor    String   @default("#10b981")
  secondaryColor  String   @default("#059669")
  phone           String   @default("0555 123 45 67")
  email           String   @default("info@gunentemizlik.com")
  address         String?
  workingHours    String   @default("7/24 Hizmet")
  whatsapp        String?
  facebook        String?
  instagram       String?
  twitter         String?
  seoTitle        String?
  seoDescription  String?
  seoKeywords     String?
  ogImage         String?
  twitterHandle   String?
  canonicalUrl    String?
  googleAnalyticsId String?
  googleTagManagerId String?
  facebookPixelId String?
  robotsTxt       String?
  sitemapEnabled  Boolean  @default(true)
  maintenanceMode Boolean  @default(false)
  customCss       String?
  customJs        String?
  updatedAt       DateTime @updatedAt

  @@map("sitesettings")
}

model Gallery {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?
  image       String
  category    String
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("gallery")
}

model Certificate {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?
  image       String
  issuer      String?
  date        DateTime?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("certificates")
}

model faq {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  question  String
  answer    String
  category  String   @default("Genel")
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("faq")
}

model Pricing {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  serviceName String
  basePrice   Float
  pricePerSqm Float?
  unit        String   @default("m²")
  minPrice    Float?
  description String?
  features    String[]
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("pricing")
}

model TeamMember {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  role        String
  bio         String?
  image       String?
  phone       String?
  email       String?
  linkedin    String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("team_members")
}

enum Role {
  USER
  ADMIN
}
